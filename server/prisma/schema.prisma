generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ExchangeStatus {
  WAITING_PAYMENT
  PAYMENT_RECEIVED
  PROCESSING
  COMPLETED
  CANCELLED
  EXPIRED
  FAILED
}

enum Role {
  USER
  ADMIN
}

enum Provider {
  GOOGLE
}

model User {
  id       String    @id @default(uuid())
  email    String    @unique
  password String?
  provider Provider?
  role     Role[]
  Token    Token[]

  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")
  exchangeRequests ExchangeRequest[]

  @@map("users")
}

model Token {
  token     String   @unique
  exp       DateTime
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  userAgent String   @map("user_agent")

  @@map("tokens")
}

model Coin {
  id       String  @id @default(uuid())
  symbol   String  @unique
  name     String
  imageUrl String?
  isActive Boolean @default(true)

  networks Network[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Network {
  id String @id @default(uuid())

  coin   Coin   @relation(fields: [coinId], references: [id], onDelete: Cascade)
  coinId String

  name      String
  chainName String

  isDefault Boolean @default(false)
  isActive  Boolean @default(true)

  withdrawFee Decimal  @db.Decimal(30, 10)
  withdrawMin Decimal  @db.Decimal(30, 10)
  withdrawMax Decimal? @db.Decimal(30, 10)
  depositDust Decimal? @db.Decimal(30, 10)

  addressRegex String
  memoRegex    String?
  requiresMemo Boolean @default(false)

  minConfirm           Int?
  estimatedArrivalTime Int?

  contractAddress String?
  explorerUrl     String?

  depositAddress String
  depositMemo    String?

  exchangeRequestsFrom ExchangeRequest[] @relation("NetworkFrom")
  exchangeRequestsTo   ExchangeRequest[] @relation("NetworkTo")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([coinId, name])
}

model ExchangeRequest {
  id String @id @default(uuid())

  user   User   @relation(fields: [userId], references: [id])
  userId String

  networkFrom   Network @relation("NetworkFrom", fields: [networkFromId], references: [id])
  networkFromId String

  networkTo   Network @relation("NetworkTo", fields: [networkToId], references: [id])
  networkToId String

  amount       Decimal @db.Decimal(30, 10)
  commission   Decimal @db.Decimal(30, 10)
  exchangeRate Decimal @db.Decimal(30, 10)
  totalReceive Decimal @db.Decimal(30, 10)

  depositAddress   String
  recipientAddress String
  recipientMemo    String?

  txHash String?

  status ExchangeStatus @default(WAITING_PAYMENT)

  paidAt      DateTime?
  completedAt DateTime?
  expiresAt   DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
